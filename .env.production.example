# Production Environment Variables
# Copy this file to .env.production and fill in the actual values

# Booking System Configuration
# Replace with your actual booking system URL (Fresha, Calendly, or Square)
VITE_BOOKING_URL=https://your-booking-system-url.com

# Contact Information
# Phone number for click-to-call functionality
VITE_PHONE_NUMBER=9994421126
# WhatsApp number with country code (91 for India)
VITE_WHATSAPP_NUMBER=919994421126

# Social Media Links
# Replace with your actual social media profile URLs
VITE_INSTAGRAM_URL=https://instagram.com/cutsandcomb
VITE_FACEBOOK_URL=https://facebook.com/cutsandcomb

# Google Maps
# Get your embed URL from Google Maps:
# 1. Go to Google Maps and search for your salon location
# 2. Click "Share" button
# 3. Click "Embed a map" tab
# 4. Copy the src URL from the iframe code
VITE_GOOGLE_MAPS_EMBED_URL=https://maps.google.com/maps?q=Cuts+%26+Comb+Salon+Porur+Chennai&output=embed
VITE_GOOGLE_MAPS_LINK=https://maps.app.goo.gl/AeKqXZV2YKDh4yR57

# Location Information
VITE_SALON_ADDRESS=Porur, Chennai
VITE_SALON_CITY=Chennai
VITE_SALON_STATE=Tamil Nadu
